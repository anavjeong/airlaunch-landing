{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/airlauch-v4.html"
    },
    {
      "src": "/waitlist",
      "dest": "/waitlist.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
